{
  "extends": [
    "development"
  ],
  "hints": {
    "apple-touch-icons": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "user-select",
          "-webkit-mask",
          "-webkit-text-size-adjust",
          "-moz-appearance"
        ]
      }
    ],
    "disown-opener": "off"
  }
}